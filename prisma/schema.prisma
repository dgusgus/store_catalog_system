generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum DiscountType {
  PERCENT   // porcentaje: 10 = 10% de descuento
  FIXED     // monto fijo: 50 = $50 de descuento
}

enum OrderStatus {
  PENDING    // recién creado, esperando al admin
  CONFIRMED  // admin aceptó
  REJECTED   // admin rechazó, stock devuelto
  DELIVERED  // entregado
}

// ── Auth ───────────────────────────────────────────────────
model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String?
  password      String
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  orders        Order[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── Catálogo ───────────────────────────────────────────────
model Category {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?

  parentId  Int?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")

  products  Product[]
  createdAt DateTime   @default(now())
}

model Product {
  id           Int            @id @default(autoincrement())
  name         String
  slug         String         @unique
  description  String?
  price        Decimal        @db.Decimal(10, 2)
  comparePrice Decimal?       @db.Decimal(10, 2)
  published    Boolean        @default(false)

  categoryId Int
  category   Category       @relation(fields: [categoryId], references: [id])

  variants  Variant[]
  images    ProductImage[]
  tags      Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([published])
  @@index([price])
}

model Variant {
  id    Int     @id @default(autoincrement())
  sku   String  @unique
  name  String
  stock Int     @default(0)
  price Decimal? @db.Decimal(10, 2)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt  DateTime    @default(now())
  orderItems OrderItem[]

  @@index([productId])
}

model ProductImage {
  id       Int     @id @default(autoincrement())
  url      String
  publicId String?
  alt      String?
  position Int     @default(0)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Tag {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Discount {
  id        Int          @id @default(autoincrement())
  code      String       @unique
  type      DiscountType
  value     Decimal      @db.Decimal(10, 2)
  minAmount Decimal?     @db.Decimal(10, 2)
  maxUses   Int?
  usedCount Int          @default(0)
  active    Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())
}

// ── Configuración de la tienda ─────────────────────────────
model StoreSettings {
  id               Int      @id @default(1)
  whatsappNumber   String?
  storeName        String?
  storeDescription String?
  updatedAt        DateTime @updatedAt
}

// ── Órdenes ────────────────────────────────────────────────
model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique

  status OrderStatus @default(PENDING)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  // Snapshot de contacto al momento del pedido
  customerName  String
  customerPhone String

  // Totales
  subtotal       Decimal @db.Decimal(10, 2)
  discountCode   String?
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  total          Decimal @db.Decimal(10, 2)

  // Nota del admin al aceptar o rechazar
  adminNote String?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Referencias vivas
  productId Int
  variantId Int?
  variant   Variant? @relation(fields: [variantId], references: [id])

  // Snapshot — precio y nombre al momento de comprar
  productName String
  variantName String?
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int
  subtotal    Decimal @db.Decimal(10, 2)

  @@index([orderId])
}
